# Google Maps API
GOOGLE_MAPS_API_KEY=

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Email Provider (sendgrid, mailgun, or ses)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Server
PORT=3001
WS_PORT=3002
SENTINEL_PORT=3003

# Limits
DAILY_TOKEN_LIMIT=5000000
DAILY_EMAIL_LIMIT=200
MAX_EMAILS_PER_HOUR=50

# Site hosting
SITE_BASE_URL=http://localhost:3001/sites
